# ---- Microsoft Graph (delegated auth via ROPC) ----
# App registration (public client) tenant + client id
GRAPH_TENANT_ID=your-tenant-id
GRAPH_CLIENT_ID=your-client-id
# If your app registration is a confidential client, set the secret (optional for public clients)
GRAPH_CLIENT_SECRET=
# The signed-in user the bot acts as (sends/reads the 1:1 chats). Must NOT require MFA for ROPC.
GRAPH_USERNAME=quizbot@yourtenant.onmicrosoft.com
GRAPH_PASSWORD=your-password

# Delegated permissions required on the app registration:
#   Chat.ReadWrite, Chat.Create, ChatMessage.Send
#   (User.Read is a default, auto-consented scope used for GET /me — no admin consent needed)
# Note: participant CSV emails must be the users' sign-in addresses (UPNs); the bot
# opens chats by binding to that address directly, so no directory-read permission is required.

# ---- Web server ----
PORT=3000
# Bind to localhost by default (admin UI has no auth)
HOST=127.0.0.1

# ---- Persistence ----
DB_PATH=./data

# ---- Quiz engine ----
# How often the engine polls Teams chats for replies (ms)
POLL_INTERVAL_MS=15000
# How long to wait for a valid answer before timing out a question (ms)
QUESTION_TIMEOUT_MS=300000
